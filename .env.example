# Example environment variables (do not commit .env files)
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_PROTO=False

# Database settings
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# AI settings (optional)
AI_PROVIDER=stub
AI_MAX_TOKENS=650
GITHUB_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
# GITHUB_TOKEN=your_github_pat_token

# Google login via django-allauth (optional: can also be configured in admin SocialApp)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_SITE_NAME=Cow Calving Assistant

# Django sites (django-allauth)
SITE_ID=1

# Email (Brevo SMTP defaults)
# For testing, use: django.core.mail.backends.console.EmailBackend
# For Brevo API, use: accounts.email_backends.BrevoAPIEmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_brevo_login_email
EMAIL_HOST_PASSWORD=your_brevo_smtp_key
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@example.com
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_API_TIMEOUT=15
BREVO_SENDER_NAME=Cow Calving
BREVO_SANDBOX_MODE=False
